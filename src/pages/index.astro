---
/**
 * Home page. Structure:
 *   1. Hero       — full-viewport muted reel (placeholder) + headline + CTAs
 *   2. Featured   — grid of featured films from the films collection
 *   3. About      — short teaser → /about
 *   4. Testimonials
 *   5. Final CTA  — book an enquiry
 *
 * LocalBusiness JSON-LD is injected via the Base layout's `jsonld` slot.
 */
import { getCollection } from "astro:content";
import Base from "~/layouts/Base.astro";
import HeroReel from "~/components/HeroReel.astro";
import FilmCard from "~/components/FilmCard.astro";
import Testimonials from "~/components/Testimonials.astro";
import JsonLd from "~/components/JsonLd.astro";
import { SITE } from "~/config";

// Featured films, newest first.
const films = (await getCollection("films", ({ data }) => data.featured && !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${SITE.url}#business`,
  name: SITE.name,
  url: SITE.url,
  email: SITE.email,
  description: SITE.description,
  image: `${SITE.url}/logo.png`,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: SITE.location.city,
    addressRegion: SITE.location.region,
    addressCountry: SITE.location.country,
  },
  areaServed: [
    { "@type": "City", name: "Thunder Bay" },
    { "@type": "AdministrativeArea", name: "Northwestern Ontario" },
  ],
  makesOffer: {
    "@type": "Offer",
    itemOffered: {
      "@type": "Service",
      name: "Wedding videography",
    },
  },
};
---

<Base
  title="Home"
  description={SITE.description}
>
  <JsonLd slot="jsonld" data={localBusiness} />

  {/* ───────── Hero ───────── */}
  <section class="relative flex min-h-[88dvh] items-end overflow-hidden">
    {/*
      TKTK — drop your muted MP4 loop at public/videos/hero.mp4, then set
      src="/videos/hero.mp4" below. Keep the file under 10MB.
    */}
    <HeroReel src="" poster="" />

    <div class="relative mx-auto w-full max-w-[var(--container-max)] px-6 pt-40 pb-24">
      <p class="text-xs tracking-[0.3em] text-[color:var(--color-bone-soft)] uppercase">
        Wedding films — Thunder Bay
      </p>
      <h1
        class="mt-6 max-w-4xl font-serif text-5xl leading-[1.02] md:text-7xl lg:text-8xl"
      >
        The day you'll want<br />
        to watch again.
      </h1>
      <p
        class="mt-8 max-w-xl text-lg text-[color:var(--color-bone-soft)] md:text-xl"
      >
        Cinematic wedding and event films, quietly made. Based in Thunder Bay,
        available across Northwestern Ontario and beyond.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-[color:var(--color-bone)] px-6 py-3 text-sm tracking-[0.15em] text-[color:var(--color-ink)] uppercase transition-colors hover:bg-[color:var(--color-ember)]"
        >
          Enquire about your date
        </a>
        <a
          href="/films"
          class="inline-flex items-center gap-2 border border-[color:var(--color-line)] px-6 py-3 text-sm tracking-[0.15em] text-[color:var(--color-bone)] uppercase transition-colors hover:border-[color:var(--color-bone)]"
        >
          Watch the films →
        </a>
      </div>
    </div>
  </section>

  {/* ───────── Featured films ───────── */}
  <section class="mx-auto max-w-[var(--container-max)] px-6 py-24" aria-labelledby="featured-heading">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-xs tracking-[0.3em] text-[color:var(--color-bone-soft)] uppercase">
          Featured films
        </p>
        <h2 id="featured-heading" class="mt-4 font-serif text-4xl md:text-5xl">
          Recent work.
        </h2>
      </div>
      <a
        href="/films"
        class="hidden text-sm tracking-widest text-[color:var(--color-bone-soft)] uppercase hover:text-[color:var(--color-bone)] md:inline-block"
      >
        All films →
      </a>
    </div>

    {
      films.length === 0 ? (
        <p class="mt-12 text-[color:var(--color-bone-soft)]">
          TKTK — no featured films yet. Mark `featured: true` on a film entry.
        </p>
      ) : (
        <ul class="mt-14 grid gap-12 md:grid-cols-2 lg:grid-cols-3">
          {films.map((film) => (
            <li>
              <FilmCard film={film} />
            </li>
          ))}
        </ul>
      )
    }

    <a
      href="/films"
      class="mt-10 inline-block text-sm tracking-widest text-[color:var(--color-bone-soft)] uppercase hover:text-[color:var(--color-bone)] md:hidden"
    >
      All films →
    </a>
  </section>

  {/* ───────── About teaser ───────── */}
  <section class="border-t border-[color:var(--color-line)]">
    <div class="mx-auto grid max-w-[var(--container-max)] gap-12 px-6 py-24 md:grid-cols-[1fr_1.2fr] md:items-center">
      <div>
        <p class="text-xs tracking-[0.3em] text-[color:var(--color-bone-soft)] uppercase">
          About
        </p>
        <h2 class="mt-4 font-serif text-4xl md:text-5xl">
          Quiet, present, close to the details.
        </h2>
      </div>
      <div>
        <p class="text-lg leading-[1.7] text-[color:var(--color-bone-soft)]">
          TKTK — short about teaser, two to three sentences. What makes your
          approach different? Keep it sincere. The goal here is to make a
          stranger feel like they already know how you'll show up on their day.
        </p>
        <a
          href="/about"
          class="mt-8 inline-block border-b border-[color:var(--color-bone-soft)] pb-1 text-sm tracking-widest text-[color:var(--color-bone)] uppercase hover:border-[color:var(--color-ember)] hover:text-[color:var(--color-ember)]"
        >
          More about Torin →
        </a>
      </div>
    </div>
  </section>

  {/* ───────── Testimonials ───────── */}
  <Testimonials />

  {/* ───────── Final CTA ───────── */}
  <section class="border-t border-[color:var(--color-line)]">
    <div class="mx-auto max-w-[var(--container-max)] px-6 py-28 text-center">
      <p class="text-xs tracking-[0.3em] text-[color:var(--color-bone-soft)] uppercase">
        Let's talk
      </p>
      <h2 class="mt-4 font-serif text-4xl leading-[1.1] md:text-6xl">
        Booking a limited number of<br />weddings each year.
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg text-[color:var(--color-bone-soft)]">
        Share a few details about your day and I'll be in touch within two
        business days.
      </p>
      <a
        href="/contact"
        class="mt-10 inline-flex items-center gap-2 bg-[color:var(--color-bone)] px-6 py-3 text-sm tracking-[0.15em] text-[color:var(--color-ink)] uppercase transition-colors hover:bg-[color:var(--color-ember)]"
      >
        Start an enquiry
      </a>
    </div>
  </section>
</Base>
